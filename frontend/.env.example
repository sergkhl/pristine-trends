NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Publishable key (sb_publishable_...). See https://supabase.com/docs/guides/api/api-keys
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# GitHub Pages project site (no trailing slash). CI sets this automatically. Local dev: leave unset for "/".
# BASE_PATH=/your-repo-name
