# Poller (npm run build && npm run start). Copy to .env and fill in — never commit .env.
# See README.md for where to obtain each value.

# Telegram (GramJS) — https://my.telegram.org/apps
TELEGRAM_SESSION=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Google AI Studio — https://aistudio.google.com/apikey
GOOGLE_AI_KEY=

# Hugging Face Inference (Whisper) — https://huggingface.co/settings/tokens
HF_API_KEY=

# Supabase — https://supabase.com/dashboard → Project Settings → API
# Use service_role JWT or secret key (server only; never in the browser).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

TAVILY_API_KEY=
# Tavily Extract: basic (default) or advanced — https://docs.tavily.com/documentation/api-reference/endpoint/extract
# TAVILY_EXTRACT_DEPTH=basic
# Timeout in seconds (1–60). Default 25.
# TAVILY_EXTRACT_TIMEOUT_SEC=25

# Link summarization: max characters of extracted page text sent to Gemma (default 12000).
# LINK_SUMMARY_MAX_EXTRACT_CHARS=12000
# PDF document summarization: max characters of extracted text sent to Gemma (default 12000).
# DOC_SUMMARY_MAX_EXTRACT_CHARS=12000
# Optional: only summarize when text_score >= this (unset = summarize all messages that have a link).
# LINK_SUMMARY_MIN_SCORE=4

# Pipeline ingest window (optional). Cursor stored per channel in `channels.ingest_cursor_published_at`.
# PIPELINE_DEFAULT_LOOKBACK_HOURS=24
# PIPELINE_CURSOR_OVERLAP_MINUTES=15

# Comment summarization (Telegram linked discussion). Defaults: 48h window, min 5 replies, 50 posts/run, 400ms between GetReplies.
# COMMENT_SUMMARY_WINDOW_HOURS=48
# COMMENT_SUMMARY_MIN_COUNT=5
# COMMENT_SUMMARY_MAX_POSTS_PER_RUN=50
# COMMENT_SUMMARY_DELAY_MS=400
# Skip comment LLM when post text is non-empty but shorter than this (default 100). Media-only posts are not skipped.
# COMMENT_SUMMARY_MIN_TEXT_LENGTH=100

# Verbose Gemma + link-preview logs (console.debug). Optional.
# PIPELINE_DEBUG=1

# One-off backfill link summaries: npm run backfill-link-summaries
# BACKFILL_HOURS=48
# BACKFILL_LIMIT=100
# BACKFILL_DRY_RUN=1
